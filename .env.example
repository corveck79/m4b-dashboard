# ── Honeygain ─────────────────────────────────────────────────
HONEYGAIN_EMAIL=your@email.com
HONEYGAIN_PASSWORD=yourpassword

# ── EarnApp ───────────────────────────────────────────────────
# Get from browser devtools: Application > Cookies > oauth-refresh-token
EARNAPP_OAUTH_REFRESH_TOKEN=

# ── IPRoyal Pawns ─────────────────────────────────────────────
IPROYAL_EMAIL=your@email.com
IPROYAL_PASSWORD=yourpassword

# ── PacketStream ──────────────────────────────────────────────
# Found in PacketStream dashboard under Account > API
PACKETSTREAM_API_KEY=

# ── Traffmonetizer ────────────────────────────────────────────
# Found in Traffmonetizer dashboard under Settings > API Token
TRAFFMONETIZER_TOKEN=

# ── Container names (defaults match standard M4B stack) ───────
CONTAINER_HONEYGAIN=honeygain
CONTAINER_EARNAPP=earnapp
CONTAINER_IPROYAL=iproyal_pawns
CONTAINER_PACKETSTREAM=packetstream
CONTAINER_TRAFFMONETIZER=traffmonetizer

# ── Scheduler ─────────────────────────────────────────────────
COLLECT_INTERVAL_MINUTES=15
